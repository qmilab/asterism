{
  "name": "@qmilab/asterism-adapter-pi",
  "version": "0.1.0",
  "description": "Runs Asterism agents on the Pi agent runtime. You probably want @qmilab/asterism.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/qmilab/asterism#readme",
  "bugs": "https://github.com/qmilab/asterism/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmilab/asterism.git",
    "directory": "packages/adapter-pi"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
