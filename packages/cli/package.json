{
  "name": "@qmilab/asterism",
  "version": "0.4.0",
  "description": "Many agents. One runtime. Separate lives. Run distinct local AI agents — each with its own soul, memory, secrets, skills, workspace, and autonomy level.",
  "keywords": [
    "ai",
    "agents",
    "cli",
    "local-first",
    "autonomy"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/qmilab/asterism#readme",
  "bugs": "https://github.com/qmilab/asterism/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmilab/asterism.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "asterism": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "bun test"
  },
  "dependencies": {
    "@qmilab/asterism-core": "workspace:*",
    "@qmilab/asterism-adapter-pi": "workspace:*",
    "@qmilab/asterism-adapter-lodestar": "workspace:*",
    "@qmilab/asterism-reflect": "workspace:*",
    "@qmilab/asterism-recall-local": "workspace:*",
    "@qmilab/asterism-server": "workspace:*",
    "@qmilab/asterism-channels": "workspace:*"
  }
}
