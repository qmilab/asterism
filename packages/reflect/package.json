{
  "name": "@qmilab/asterism-reflect",
  "version": "0.2.0",
  "description": "Proposes reviewable, typed memories for Asterism agents from their run transcripts. You probably want @qmilab/asterism.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/qmilab/asterism#readme",
  "bugs": "https://github.com/qmilab/asterism/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmilab/asterism.git",
    "directory": "packages/reflect"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "bun test"
  },
  "dependencies": {
    "@qmilab/asterism-core": "workspace:*"
  }
}
